NODE_ENV=development

# local infra
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/axioma_learn
REDIS_URL=redis://localhost:6379

# api
PORT=4000

# auth
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=

# ai
OPENAI_API_KEY=

# analytics / errors
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# storage
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# web public
NEXT_PUBLIC_APP_NAME=Axioma Learn
NEXT_PUBLIC_API_URL=http://localhost:4000
