{
  "name": "@axioma/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo \"No DB lint configured yet\"",
    "typecheck": "tsc --noEmit",
