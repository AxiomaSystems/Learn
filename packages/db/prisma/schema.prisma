generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  STUDENT
  EDUCATOR
  TEACHING_ASSISTANT
  INSTITUTION_ADMIN
  PLATFORM_ADMIN
}

enum CourseworkKind {
  READING
  ASSIGNMENT
  DISCUSSION
  PREP
  QUIZ
  PROJECT
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  RETURNED
}

enum BookingStatus {
  BOOKED
  CANCELLED
  COMPLETED
}

model Institution {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  timezone  String   @default("America/Chicago")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  classes Class[]
}

model User {
  id            String   @id @default(uuid())
  institutionId String
  email         String   @unique
  fullName      String
  role          AppRole
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution               Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  taughtClasses             Class[]            @relation("EducatorClasses")
  submissions               Submission[]
  officeHourBookings        OfficeHourBooking[]
  createdOfficeHourSlots    OfficeHourSlot[]   @relation("EducatorOfficeHours")
  auditEvents               AuditEvent[]
  aiInteractions            AIInteraction[]
}

model Class {
  id            String   @id @default(uuid())
  institutionId String
  educatorId    String
  code          String
  title         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution     Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  educator        User             @relation("EducatorClasses", fields: [educatorId], references: [id], onDelete: Restrict)
  courseworkItems Coursework[]
  resources       Resource[]
  officeHourSlots OfficeHourSlot[]
}

model Coursework {
  id         String         @id @default(uuid())
  classId    String
  title      String
  kind       CourseworkKind
  description String?
  topic      String?
  dueAt      DateTime
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  resources   Resource[]
  submissions Submission[]
}

model Resource {
  id           String   @id @default(uuid())
  classId       String
  courseworkId  String?
  title         String
  storageKey    String?
  externalUrl   String?
  createdAt     DateTime @default(now())

  class      Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  coursework Coursework? @relation(fields: [courseworkId], references: [id], onDelete: SetNull)
}

model Submission {
  id           String           @id @default(uuid())
  courseworkId String
  studentId    String
  status       SubmissionStatus @default(DRAFT)
  storageKey   String?
  fileName     String?
  mimeType     String?
  fileSizeBytes Int?
  gradeScore   Int?
  feedbackText String?
  submittedAt  DateTime?
  gradedAt     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @default(now()) @updatedAt

  coursework Coursework @relation(fields: [courseworkId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model OfficeHourSlot {
  id          String   @id @default(uuid())
  classId      String
  educatorId   String
  startsAt     DateTime
  endsAt       DateTime
  location     String
  mode         String
  createdAt    DateTime @default(now())

  class     Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  educator  User                @relation("EducatorOfficeHours", fields: [educatorId], references: [id], onDelete: Cascade)
  bookings  OfficeHourBooking[]
}

model OfficeHourBooking {
  id              String        @id @default(uuid())
  officeHourSlotId String
  studentId       String
  topic           String?
  status          BookingStatus @default(BOOKED)
  bookedAt        DateTime      @default(now())

  officeHourSlot OfficeHourSlot @relation(fields: [officeHourSlotId], references: [id], onDelete: Cascade)
  student        User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id            String   @id @default(uuid())
  institutionId String
  actorUserId   String
  action        String
  entityType    String
  entityId      String
  payload       Json?
  createdAt     DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
}

model AIInteraction {
  id            String   @id @default(uuid())
  institutionId String
  actorUserId   String
  roleContext   String
  classId       String?
  courseworkId  String?
  prompt        String
  response      String?
  createdAt     DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
}
